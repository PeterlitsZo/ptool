#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:1
msgid "Hash API"
msgstr "API de hash"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:3
msgid "Hashing helpers are available under `ptool.hash` and `p.hash`."
msgstr "As utilidades de hash estão disponíveis em `ptool.hash` e `p.hash`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:5
msgid "ptool.hash.sha256"
msgstr "ptool.hash.sha256"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:7"
msgid "`v0.2.0` - Introduced."
msgstr "`v0.2.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:9
msgid "`ptool.hash.sha256(input)` returns the SHA-256 digest of a Lua string."
msgstr "`ptool.hash.sha256(input)` retorna o digest SHA-256 de uma string Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:11
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:11"
msgid "`input` (string, required): The input Lua string. The digest is computed from the string's raw bytes."
msgstr "`input` (string, obrigatório): A string Lua de entrada. O digest é calculado a partir dos bytes brutos da string."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:13
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/hash.md:13"
msgid "Returns: `string` (lowercase hexadecimal digest)."
msgstr "Retorna: `string` (digest hexadecimal em minúsculas)."

