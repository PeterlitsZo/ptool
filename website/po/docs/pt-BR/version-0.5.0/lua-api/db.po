msgstr "`db:scalar(sql, params?)` -> `boolean|integer|number|string|nil`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/db.md:64
msgid "`db:execute(sql, params?)` -> `table`"
msgstr "`db:execute(sql, params?)` -> `table`"

