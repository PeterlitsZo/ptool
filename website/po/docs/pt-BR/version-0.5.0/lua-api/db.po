msgid "SQLite"
msgstr "SQLite"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/db.md:15
msgid "PostgreSQL"
msgstr "PostgreSQL"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/db.md:16
msgid "MySQL"
msgstr "MySQL"

