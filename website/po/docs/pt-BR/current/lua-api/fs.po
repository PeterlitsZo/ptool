#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:73
msgid "ptool.fs.open"
msgstr "ptool.fs.open"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:75
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:75"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:77
msgid ""
"`ptool.fs.open(path[, mode])` opens a local file and returns a `File` object."
msgstr ""
"`ptool.fs.open(path[, mode])` abre um arquivo local e retorna um objeto "
"`File`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:79
msgid "Arguments:"
msgstr "Argumentos:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:81
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:81"
msgid "`path` (string, required): The file path."
msgstr "`path` (string, obrigatório): O caminho do arquivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:82
msgid "`mode` (string, optional): The file mode. Defaults to `\"r\"`."
msgstr "`mode` (string, opcional): O modo do arquivo. O padrão é `\"r\"`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:84
msgid "Supported modes:"
msgstr "Modos suportados:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:86
msgid "`\"r\"`: Open for reading."
msgstr "`\"r\"`: Abre para leitura."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:87
msgid ""
"`\"w\"`: Open for writing, truncating existing contents and creating the "
"file when needed."
msgstr ""
"`\"w\"`: Abre para escrita, truncando o conteúdo existente e criando o "
"arquivo quando necessário."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:89
msgid "`\"a\"`: Open for appending, creating the file when needed."
msgstr "`\"a\"`: Abre para anexar, criando o arquivo quando necessário."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:90
msgid "`\"r+\"`: Open for reading and writing without truncation."
msgstr "`\"r+\"`: Abre para leitura e escrita sem truncar."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:91
msgid ""
"`\"w+\"`: Open for reading and writing, truncating existing contents and "
"creating the file when needed."
msgstr ""
"`\"w+\"`: Abre para leitura e escrita, truncando o conteúdo existente e "
"criando o arquivo quando necessário."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:93
msgid ""
"`\"a+\"`: Open for reading and appending, creating the file when needed."
msgstr ""
"`\"a+\"`: Abre para leitura e anexação, criando o arquivo quando necessário."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:95
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:95"
msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:97
msgid "Modes may include `b`, such as `\"rb\"` or `\"w+b\"`."
msgstr "Os modos podem incluir `b`, como `\"rb\"` ou `\"w+b\"`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:98
msgid "`a` and `a+` writes always go to the end of the file."
msgstr "As escritas com `a` e `a+` sempre vão para o fim do arquivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:100
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:100"
msgid "Example:"
msgstr "Exemplo:"

