msgid "ptool.fs.write"
msgstr "ptool.fs.write"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:31
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:31"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:33
msgid ""
"`ptool.fs.write(path, content)` writes a Lua string to a file as raw bytes, "
"overwriting existing contents."
msgstr ""
"`ptool.fs.write(path, content)` grava uma string Lua em um arquivo como "
"bytes brutos, sobrescrevendo o conteúdo existente."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:36
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:36"
msgid "`path` (string, required): The file path."
msgstr "`path` (string, obrigatório): O caminho do arquivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:37
msgid "`content` (string, required): The content to write."
msgstr "`content` (string, obrigatório): O conteúdo a gravar."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:39
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:39"
msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:41
msgid "`content` is written byte-for-byte."
msgstr "`content` é gravado byte por byte."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:42
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:42"
msgid "Embedded NUL bytes and non-UTF-8 bytes are preserved."
msgstr "Bytes NUL embutidos e bytes não UTF-8 são preservados."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:44
