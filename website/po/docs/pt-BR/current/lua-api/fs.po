msgid "`file:flush()` -> `nil`"
msgstr "`file:flush()` -> `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:122
msgid "`file:seek([whence[, offset]])` -> `integer`"
msgstr "`file:seek([whence[, offset]])` -> `integer`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:123
msgid "`file:close()` -> `nil`"
msgstr "`file:close()` -> `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:125
msgid "read"
msgstr "read"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:127
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:127"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:129
msgid "Canonical API name: `ptool.fs.File:read`."
msgstr "Nome canônico da API: `ptool.fs.File:read`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:131
msgid ""
"`file:read([n])` reads bytes from the current file position and returns them "
"as a Lua string."
msgstr ""
"`file:read([n])` lê bytes a partir da posição atual do arquivo e os retorna "
"como uma string Lua."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:134
msgid ""
"`n` (integer, optional): The maximum number of bytes to read. If omitted, "
"reads from the current file position to EOF."
msgstr ""
"`n` (integer, opcional): O número máximo de bytes a ler. Se omitido, lê da "
"posição atual até EOF."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:136
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:136"
msgid "Returns: `string`."
msgstr "Retorna: `string`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:138
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:138"
msgid "Behavior:"
msgstr "Comportamento:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:140
msgid "Returns an empty string at EOF."
msgstr "Retorna uma string vazia em EOF."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:141
msgid "Reads raw bytes, so binary data is preserved exactly."
msgstr "Lê bytes brutos, então os dados binários são preservados exatamente."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:143
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:143"
msgid "Example:"
msgstr "Exemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:152
msgid "write"
msgstr "write"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:154
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:154"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:156
msgid "Canonical API name: `ptool.fs.File:write`."
msgstr "Nome canônico da API: `ptool.fs.File:write`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:158
msgid "`file:write(content)` writes a Lua string at the current file position."
msgstr "`file:write(content)` grava uma string Lua na posição atual do arquivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:160
msgid "`content` (string, required): The bytes to write."
msgstr "`content` (string, obrigatório): Os bytes a gravar."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:162
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:162"
msgid "Behavior:"
msgstr "Comportamento:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:164
msgid "Writes raw bytes exactly as provided."
msgstr "Grava bytes brutos exatamente como foram fornecidos."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:165
msgid "On append-mode handles, writes are appended to the end of the file."
msgstr ""
"Em identificadores no modo append, as escritas são anexadas ao fim do "
"arquivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:167
msgid "flush"
msgstr "flush"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:169
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:169"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:171
msgid "Canonical API name: `ptool.fs.File:flush`."
msgstr "Nome canônico da API: `ptool.fs.File:flush`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:173
msgid "`file:flush()` flushes buffered file writes to the OS."
msgstr ""
"`file:flush()` descarrega para o SO as escritas em arquivo que estão em "
"buffer."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:175
msgid "seek"
msgstr "seek"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:177
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:177"
