#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:1
msgid "Lua API Overview"
msgstr "Visão geral da API de Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:3
msgid "`ptool` exposes a broad set of helpers through `ptool` and `p`."
msgstr "`ptool` expõe um amplo conjunto de utilitários por meio de `ptool` e `p`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:5
msgid "Core APIs"
msgstr "APIs principais"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:7
msgid "[Core Lua API]{1}: Script lifecycle, process execution, config, and terminal helpers."
msgstr "[API principal de Lua]{1}: Ciclo de vida do script, execução de processos, configuração e utilitários de terminal."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:10
msgid "Modules"
msgstr "Módulos"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:12
msgid "[Args API]{1}: Command-line argument schema parsing for Lua scripts."
msgstr "[API de argumentos]{1}: Parse de esquemas de argumentos de linha de comando para scripts Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:13
msgid "[SemVer API]{1}: Parse, compare, and bump semantic versions."
msgstr "[API de SemVer]{1}: Faz parse, compara e incrementa versões semânticas."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:14
msgid "[Hash API]{1}: Compute SHA-256, SHA-1, and MD5 digests."
msgstr "[API de hash]{1}: Calcula digests SHA-256, SHA-1 e MD5."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:15
msgid "[Network API]{1}: Parse URLs, IP addresses, and host-port pairs."
msgstr "[API de rede]{1}: Faz parse de URLs, endereços IP e pares host-porta."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:16
msgid "[OS API]{1}: Read runtime environment variables and inspect host process details."
msgstr "[API de sistema operacional]{1}: Lê variáveis de ambiente do runtime e inspeciona detalhes do processo hospedeiro."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:18
msgid "[Platform API]{1}: Detect the current OS, architecture, and target triple."
msgstr "[API de plataforma]{1}: Detecta o SO, a arquitetura e o target triple atuais."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:20
msgid "[ANSI API]{1}: Build styled terminal output with ANSI escape sequences."
msgstr "[API ANSI]{1}: Monta saída de terminal com estilo usando sequências ANSI."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:22
msgid "[Log API]{1}: Write timestamped terminal logs with level-based output."
msgstr "[API de log]{1}: Escreve logs de terminal com timestamp e nível."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:23
msgid "[HTTP API]{1}: Send HTTP requests and consume response bodies."
msgstr "[API HTTP]{1}: Envia requisições HTTP e consome corpos de resposta."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:24
msgid "[JSON API]{1}: Parse JSON text and stringify Lua values as JSON."
msgstr "[API JSON]{1}: Faz parse de texto JSON e serializa valores Lua como JSON."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:25
msgid "[YAML API]{1}: Parse YAML text, read nested values, and stringify Lua values as YAML."
msgstr "[API YAML]{1}: Faz parse de texto YAML, lê valores aninhados e serializa valores Lua como YAML."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:27
msgid "[Database API]{1}: Open database connections and run SQL queries."
msgstr "[API de banco de dados]{1}: Abre conexões de banco de dados e executa consultas SQL."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:28
msgid "[SSH API]{1}: Connect to remote hosts, run commands, and transfer files."
msgstr "[API SSH]{1}: Conecta-se a hosts remotos, executa comandos e transfere arquivos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:30
msgid "[Path API]{1}: Manipulate paths lexically without touching the filesystem."
msgstr "[API de caminhos]{1}: Manipula caminhos lexicalmente sem tocar no sistema de arquivos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:32
msgid "[TOML API]{1}: Parse, stringify, read, update, and remove TOML values."
msgstr "[API TOML]{1}: Faz parse, serializa, lê, atualiza e remove valores TOML."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:33
msgid "[Regex API]{1}: Compile regexes and search, capture, replace, or split text."
msgstr "[API de regex]{1}: Compila regex e busca, captura, substitui ou divide texto."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:35
msgid "[String API]{1}: Trim, split, join, replace, and format strings."
msgstr "[API de strings]{1}: Remove espaços, divide, junta, substitui e formata strings."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:36
msgid "[Table API]{1}: Map, filter, and concatenate dense list tables."
msgstr "[API de tabelas]{1}: Mapeia, filtra e concatena tabelas de lista densas."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:37
msgid "[Filesystem API]{1}: Read, write, create, and glob filesystem paths."
msgstr "[API de sistema de arquivos]{1}: Lê, grava, cria e faz glob em caminhos do sistema de arquivos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:38
msgid "[Shell API]{1}: Split shell-like command lines into argument arrays."
msgstr "[API de shell]{1}: Divide linhas de comando em estilo shell em arrays de argumentos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:39
msgid "[Template API]{1}: Render text templates from Lua data."
msgstr "[API de templates]{1}: Renderiza templates de texto a partir de dados Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/index.md:41
msgid "Use this page as the entrypoint, then jump to the module page you need for the full function reference."
msgstr "Use esta página como ponto de entrada e depois salte para o módulo necessário para consultar a referência completa das funções."
