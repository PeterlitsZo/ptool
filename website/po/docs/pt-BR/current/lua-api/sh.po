msgid "Shell API"
msgstr "API de shell"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/sh.md:3
msgid "Shell parsing helpers are available under `ptool.sh` and `p.sh`."
msgstr "As utilidades de parsing de shell estão disponíveis em `ptool.sh` e `p.sh`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/sh.md:5
msgid "ptool.sh.split"
msgstr "ptool.sh.split"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/sh.md:7
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/sh.md:9
msgid "`ptool.sh.split(command)` parses a command string using shell-style rules and returns an argument array."
msgstr "`ptool.sh.split(command)` faz o parse de uma string de comando usando regras em estilo shell e retorna um array de argumentos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/sh.md:12
msgid "`command` (string, required): The command string to split."
msgstr "`command` (string, obrigatório): A string de comando a dividir."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/sh.md:13
msgid "Returns: `string[]`."
msgstr "Retorna: `string[]`."

