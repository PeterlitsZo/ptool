msgstr "`min_length` (integer, opcional): Comprimento mínimo aceito."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:265
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:265"
msgid "`max_length` (integer, optional): Maximum accepted character length."
msgstr "`max_length` (integer, opcional): Comprimento máximo aceito."

