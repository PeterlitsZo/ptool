msgstr ""
"`default` (boolean, opcional): Resposta padrão quando o usuário pressiona "
"Enter sem digitar."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:180
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:180"
msgid "`help` (string, optional): Extra help text shown below the prompt."
msgstr ""
"`help` (string, opcional): Texto de ajuda extra exibido abaixo do prompt."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:184
msgid "Returns: `boolean`."
msgstr "Retorna: `boolean`."

