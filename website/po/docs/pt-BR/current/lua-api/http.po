#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:1
msgid "HTTP API"
msgstr "API HTTP"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:3
msgid "HTTP client helpers are available under `ptool.http` and `p.http`."
msgstr "As utilidades de cliente HTTP estĂŁo disponĂ­veis em `ptool.http` e `p.http`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:5
msgid "ptool.http.request"
msgstr "ptool.http.request"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:7"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:9
msgid "`ptool.http.request(options)` sends an HTTP request and returns a `Response` object."
msgstr "`ptool.http.request(options)` envia uma requisiĂ§ĂŁo HTTP e retorna um objeto `Response`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:12
msgid "`options` fields:"
msgstr "Campos de `options`:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:14
msgid "`url` (string, required): The request URL."
msgstr "`url` (string, obrigatĂłrio): A URL da requisiĂ§ĂŁo."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:15
msgid "`method` (string, optional): The HTTP method. Defaults to `\"GET\"`."
msgstr "`method` (string, opcional): O mĂ©todo HTTP. O padrĂŁo Ă© `\"GET\"`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:16
msgid "`headers` (table, optional): Request headers, where both keys and values are strings."
msgstr "`headers` (table, opcional): CabeĂ§alhos da requisiĂ§ĂŁo, em que chaves e valores sĂŁo strings."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:18
msgid "`query` (table, optional): Query parameters appended to the request URL. Keys must be strings. Values may be strings, numbers, or booleans."
msgstr "`query` (table, opcional): ParĂ˘metros de consulta adicionados Ă  URL da requisiĂ§ĂŁo. As chaves devem ser strings. Os valores podem ser strings, nĂşmeros ou booleanos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:20
msgid "`body` (string, optional): The request body."
msgstr "`body` (string, opcional): O corpo da requisiĂ§ĂŁo."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:21
msgid "`json` (Lua value, optional): A Lua value encoded as JSON and used as the request body. When `content-type` is not already set, it defaults to `application/json`."
msgstr "`json` (valor Lua, opcional): Um valor Lua codificado como JSON e usado como corpo da requisiĂ§ĂŁo. Quando `content-type` nĂŁo estĂˇ definido, o padrĂŁo passa a ser `application/json`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:24
msgid "`form` (table, optional): Form fields encoded as `application/x-www-form-urlencoded` and used as the request body. Keys must be strings. Values may be strings, numbers, or booleans."
msgstr "`form` (table, opcional): Campos codificados como `application/x-www-form-urlencoded` e usados como corpo da requisiĂ§ĂŁo. As chaves devem ser strings. Os valores podem ser strings, nĂşmeros ou booleanos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:27
msgid "`timeout_ms` (integer, optional): Timeout in milliseconds. Defaults to `30000`."
msgstr "`timeout_ms` (integer, opcional): Tempo limite em milissegundos. O padrĂŁo Ă© `30000`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:29
msgid "`connect_timeout_ms` (integer, optional): Connection timeout in milliseconds."
msgstr "`connect_timeout_ms` (integer, opcional): Tempo limite de conexĂŁo em milissegundos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:30
msgid "`follow_redirects` (boolean, optional): Whether redirects should be followed."
msgstr "`follow_redirects` (boolean, opcional): Se os redirecionamentos devem ser seguidos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:31
msgid "`max_redirects` (integer, optional): Maximum number of redirects to follow."
msgstr "`max_redirects` (integer, opcional): NĂşmero mĂˇximo de redirecionamentos a seguir."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:32
msgid "`user_agent` (string, optional): Sets the `user-agent` request header."
msgstr "`user_agent` (string, opcional): Define o cabeĂ§alho `user-agent`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:33
msgid "`basic_auth` (table, optional): HTTP basic auth credentials with string fields `username` and `password`."
msgstr "`basic_auth` (table, opcional): Credenciais HTTP Basic com os campos string `username` e `password`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:35
msgid "`bearer_token` (string, optional): Bearer token used for the `authorization` header."
msgstr "`bearer_token` (string, opcional): Token Bearer usado no cabeĂ§alho `authorization`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:37
msgid "`fail_on_http_error` (boolean, optional): When `true`, raise an error for 4xx and 5xx HTTP responses. Defaults to `false`."
msgstr "`fail_on_http_error` (boolean, opcional): Quando `true`, respostas HTTP 4xx e 5xx geram erro. O padrĂŁo Ă© `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:40
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:40"
msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:42
msgid "`body`, `json`, and `form` are mutually exclusive."
msgstr "`body`, `json` e `form` sĂŁo mutuamente exclusivos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:43
msgid "`basic_auth` and `bearer_token` are mutually exclusive."
msgstr "`basic_auth` e `bearer_token` sĂŁo mutuamente exclusivos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:45
msgid "Example:"
msgstr "Exemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:69
msgid "Response"
msgstr "Response"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:71
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:71"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:73
msgid "`Response` represents an HTTP response returned by `ptool.http.request(...)`."
msgstr "`Response` representa uma resposta HTTP retornada por `ptool.http.request(...)`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:75
msgid "Fields:"
msgstr "Campos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:77
msgid "`status` (integer): The HTTP status code."
msgstr "`status` (integer): O cĂłdigo de status HTTP."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:78
msgid "`ok` (boolean): Whether the status code is in the 2xx range."
msgstr "`ok` (boolean): Se o cĂłdigo de status estĂˇ na faixa 2xx."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:79
msgid "`url` (string): The final URL after redirects."
msgstr "`url` (string): A URL final apĂłs redirecionamentos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:80
msgid "`headers` (table): A flattened convenience view of response headers (`table<string, string>`). Repeated headers are merged with `, `."
msgstr "`headers` (table): VisĂŁo simplificada dos cabeĂ§alhos da resposta (`table<string, string>`). CabeĂ§alhos repetidos sĂŁo unidos com `, `."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:83
msgid "Methods:"
msgstr "MĂ©todos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:85
msgid "`resp:text()`: Reads and returns the response body as text."
msgstr "`resp:text()`: LĂŞ e retorna o corpo da resposta como texto."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:86
msgid "`resp:json()`: Reads the response body, parses it as JSON, and returns a Lua value."
msgstr "`resp:json()`: LĂŞ o corpo da resposta, faz parse como JSON e retorna um valor Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:88
msgid "`resp:bytes()`: Reads and returns the raw bytes (as a Lua string)."
msgstr "`resp:bytes()`: LĂŞ e retorna os bytes brutos como uma string Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:89
msgid "`resp:header(name)`: Returns the first matching response header value, or `nil`."
msgstr "`resp:header(name)`: Retorna o primeiro valor de cabeĂ§alho correspondente, ou `nil`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:91
msgid "`resp:header_values(name)`: Returns all matching response header values as an array."
msgstr "`resp:header_values(name)`: Retorna todos os valores de cabeĂ§alho correspondentes como um array."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:93
msgid "`resp:raise_for_status()`: Raises an error for 4xx and 5xx HTTP responses."
msgstr "`resp:raise_for_status()`: Gera erro para respostas HTTP 4xx e 5xx."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:95
msgid "text"
msgstr "text"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:97
