msgstr "Canonical API name: `ptool.http.Response:text`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:99
msgid "`resp:text()` reads and returns the response body as text."
msgstr "`resp:text()` lĂŞ e retorna o corpo da resposta como texto."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:101
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:101"
