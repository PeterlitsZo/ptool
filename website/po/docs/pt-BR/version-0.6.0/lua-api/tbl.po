#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:97
msgid "List Rules"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:99
msgid "`ptool.tbl` currently supports only dense list tables."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:101
msgid "Keys must be integers."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:102
msgid "Keys must start at `1`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:103
msgid "Keys must be contiguous without gaps."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:104
msgid "Sparse tables and dictionary-style tables raise errors."
msgstr ""
