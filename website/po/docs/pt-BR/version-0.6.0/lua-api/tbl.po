#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:1
msgid "Table API"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:3
msgid "Table helpers are available under `ptool.tbl` and `p.tbl`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:5
msgid ""
"These APIs are designed for dense list tables with contiguous integer keys "
"starting at `1`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:8
msgid "ptool.tbl.map"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:10
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:10"
msgid "`Unreleased` - Introduced."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:12
msgid ""
"`ptool.tbl.map(list, fn)` transforms each item in a list table and returns a "
"new list."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:15
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:15"
msgid "`list` (table, required): A dense list table."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:16
msgid ""
"`fn` (function, required): A callback that receives `(value, index)` and "
"must return a non-`nil` value."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:18
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:18"
msgid "Returns: `table`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:20
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:20"
msgid "Behavior:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:22
msgid "`fn` is called once for each item in order."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:23
msgid ""
"If `fn` returns `nil`, the call raises an error instead of creating holes in "
"the result."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:25
msgid "The input table is not modified."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:35
msgid "ptool.tbl.filter"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:37
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:37"
msgid "`Unreleased` - Introduced."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:39
msgid ""
"`ptool.tbl.filter(list, fn)` keeps items whose callback result is truthy and "
"returns them in a new dense list."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:42
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:42"
msgid "`list` (table, required): A dense list table."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:43
msgid "`fn` (function, required): A callback that receives `(value, index)`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:44
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:44"
msgid "Returns: `table`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:46
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:46"
msgid "Behavior:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:48
msgid "`nil` and `false` remove the current item."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:49
msgid "Any other Lua value keeps the current item."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:50
msgid "The returned table is reindexed from `1`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:60
msgid "ptool.tbl.concat"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:62
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:62"
msgid "`Unreleased` - Introduced."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:64
msgid ""
"`ptool.tbl.concat(...)` concatenates one or more dense list tables into a "
"new list."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:67
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:67"
msgid "`...` (table, required): One or more dense list tables."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:68
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:68"
msgid "Returns: `table`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:70
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:70"
msgid "Behavior:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:72
msgid "Arguments are appended from left to right."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:73
msgid "Empty lists are allowed."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tbl.md:74
msgid "The input tables are not modified."
msgstr ""

