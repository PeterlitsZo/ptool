#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:1
msgid "JSON API"
msgstr "API JSON"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:3
msgid ""
"JSON parsing and serialization helpers are available under `ptool.json` and "
"`p.json`."
msgstr ""
"As utilidades de parse e serialização JSON estão disponíveis em `ptool.json` "
"e `p.json`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:6
msgid "ptool.json.parse"
msgstr "ptool.json.parse"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:8
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:8"
msgid "`v0.3.0` - Introduced."
msgstr "`v0.3.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:10
msgid "`ptool.json.parse(input)` parses a JSON string into a Lua value."
msgstr ""
"`ptool.json.parse(input)` faz o parse de uma string JSON em um valor Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:12
msgid "`input` (string, required): The JSON text."
msgstr "`input` (string, obrigatório): O texto JSON."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:13
msgid "Returns: The parsed Lua value. The root can be any JSON type."
msgstr "Retorna: O valor Lua analisado. A raiz pode ser qualquer tipo JSON."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:15
msgid "Type mapping:"
msgstr "Mapeamento de tipos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:17
msgid "JSON object -> Lua table"
msgstr "Objeto JSON -> tabela Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:18
msgid "JSON array -> Lua sequence table (1-based)"
msgstr "Array JSON -> tabela sequencial Lua (base 1)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:19
msgid "JSON string -> Lua string"
msgstr "String JSON -> string Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:20
msgid "JSON integer that fits in `i64` -> Lua integer"
msgstr "Inteiro JSON que cabe em `i64` -> inteiro Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:21
msgid "Other JSON number -> Lua number"
msgstr "Outro número JSON -> número Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:22
msgid "JSON boolean -> Lua boolean"
msgstr "Booleano JSON -> booleano Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:23
msgid "JSON null -> Lua `nil`"
msgstr "JSON null -> Lua `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:25
msgid "Error behavior:"
msgstr "Comportamento de erro:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:27
msgid "An error is raised if `input` is not a string."
msgstr "Um erro é gerado se `input` não for uma string."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:28
msgid ""
"A JSON syntax error raises an error whose message includes the parser detail "
"from `serde_json`."
msgstr ""
"Um erro de sintaxe JSON gera uma mensagem que inclui o detalhe do parser de "
"`serde_json`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:31
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:31"
msgid "Example:"
msgstr "Exemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:41
msgid "ptool.json.stringify"
msgstr "ptool.json.stringify"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:43
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:43"
msgid "`v0.3.0` - Introduced."
msgstr "`v0.3.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:45
msgid ""
"`ptool.json.stringify(value[, options])` converts a Lua value to a JSON "
"string."
msgstr ""
"`ptool.json.stringify(value[, options])` converte um valor Lua em uma string "
"JSON."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:47
msgid "`value` (JSON-compatible Lua value, required): The value to encode."
msgstr ""
"`value` (valor Lua compatível com JSON, obrigatório): O valor a ser "
"codificado."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:48
msgid "`options` (table, optional): Serialization options."
msgstr "`options` (table, opcional): Opções de serialização."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:49
msgid ""
"`options.pretty` (boolean, optional): When `true`, output pretty-printed "
"JSON. Defaults to `false`."
msgstr ""
"`options.pretty` (boolean, opcional): Quando `true`, produz JSON formatado. "
"O padrão é `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:51
msgid "Returns: The encoded JSON string."
msgstr "Retorna: A string JSON codificada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:53
msgid "Behavior:"
msgstr "Comportamento:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:55
msgid "Default output is compact JSON with no extra whitespace."
msgstr "A saída padrão é JSON compacto, sem espaços extras."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:56
msgid "Pretty output uses indented multi-line JSON."
msgstr "A saída pretty usa JSON indentado em múltiplas linhas."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:57
msgid ""
"Values must be JSON-compatible. Functions, threads, userdata, and other non-"
"serializable Lua values raise an error."
msgstr ""
"Os valores precisam ser compatíveis com JSON. Funções, threads, userdata e "
"outros valores Lua não serializáveis geram erro."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:60
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:60"
msgid "Example:"
msgstr "Exemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:72
msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:74
msgid ""
"`nil` values inside Lua tables follow `mlua`'s serde conversion behavior and "
"are not preserved as JSON object fields."
msgstr ""
"Valores `nil` dentro de tabelas Lua seguem o comportamento de conversão "
"serde de `mlua` e não são preservados como campos de objetos JSON."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/json.md:76
msgid ""
"Array/object detection for Lua tables follows `mlua`'s serde conversion "
"rules."
msgstr ""
"A detecção de array/objeto em tabelas Lua segue as regras de conversão serde "
"de `mlua`."

