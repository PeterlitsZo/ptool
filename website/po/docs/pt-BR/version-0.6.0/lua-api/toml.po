msgid "An error is raised if `input` is not a string."
msgstr "Um erro é gerado se `input` não for uma string."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:27
msgid ""
"A TOML syntax error raises an error whose message includes line and column "
"information."
msgstr ""
"Um erro de sintaxe TOML gera uma mensagem que inclui informações de linha e "
"coluna."

