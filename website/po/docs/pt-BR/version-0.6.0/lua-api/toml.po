#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:3
msgid ""
"TOML parsing and editing helpers are available under `ptool.toml` and "
"`p.toml`."
msgstr ""
"As utilidades de parse e edição de TOML estão disponíveis em `ptool.toml` e "
"`p.toml`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:5
msgid "ptool.toml.parse"
msgstr "ptool.toml.parse"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:7
