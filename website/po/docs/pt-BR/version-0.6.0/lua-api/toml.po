msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:170
msgid ""
"The `path` argument for `ptool.toml.get/set/remove` must be a non-empty "
"array of strings and/or positive integers."
msgstr ""
"O argumento `path` de `ptool.toml.get/set/remove` deve ser um array não "
"vazio de strings e/ou inteiros positivos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:172
msgid "Integer path segments are 1-based so they match Lua array indexing."
msgstr ""
"Segmentos de caminho inteiros usam base 1 para combinar com o indexamento de "
"arrays do Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:173
msgid "TOML datetime/date/time values are still read back as Lua strings."
msgstr "Valores TOML datetime/date/time ainda são lidos como strings Lua."

