msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:9
msgid "`ptool.toml.parse(input)` parses a TOML string into a Lua table."
msgstr ""
"`ptool.toml.parse(input)` faz o parse de uma string TOML em uma tabela Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:11
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:11"
msgid "`input` (string, required): The TOML text."
msgstr "`input` (string, obrigatório): O texto TOML."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:12
msgid "Returns: A Lua table (the root node is always a table)."
msgstr "Retorna: Uma tabela Lua (o nó raiz sempre é uma tabela)."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:14
msgid "Type mapping:"
msgstr "Mapeamento de tipos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:16
msgid "TOML table / inline table -> Lua table"
msgstr "Tabela TOML / tabela inline -> tabela Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:17
msgid "TOML array -> Lua sequence table (1-based)"
msgstr "Array TOML -> tabela sequencial Lua (base 1)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:18
msgid "TOML string -> Lua string"
msgstr "String TOML -> string Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:19
msgid "TOML integer -> Lua integer"
msgstr "Inteiro TOML -> inteiro Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:20
msgid "TOML float -> Lua number"
msgstr "Float TOML -> número Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:21
msgid "TOML boolean -> Lua boolean"
msgstr "Booleano TOML -> booleano Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:22
msgid "TOML datetime/date/time -> Lua string"
msgstr "datetime/date/time TOML -> string Lua"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:24
