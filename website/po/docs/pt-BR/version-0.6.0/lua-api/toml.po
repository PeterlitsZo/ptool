msgid ""
"`path` ((string|integer)[], required): A non-empty path array, such as `{"
"\"package\", \"name\"}` or `{\"bin\", 1}`."
msgstr ""
"`path` ((string|integer)[], obrigatório): Um array de caminho não vazio, "
"como `{\"package\", \"name\"}` ou `{\"bin\", 1}`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:123
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:123"
msgid "Returns: The updated TOML string."
msgstr "Retorna: A string TOML atualizada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/toml.md:125
