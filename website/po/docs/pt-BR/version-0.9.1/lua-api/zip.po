#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:1
msgid "Zip API"
msgstr "API Zip"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:3
msgid "Compression helpers are available under `ptool.zip` and `p.zip`."
msgstr "As utilidades de compressão estão disponíveis em `ptool.zip` e `p.zip`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:5
msgid ""
"`ptool.zip` works on raw Lua strings, so it can be used for both text and "
"binary payloads."
msgstr ""
"`ptool.zip` trabalha com strings Lua brutas, então pode ser usado tanto "
"com texto quanto com cargas binárias."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:8
msgid "Supported format names:"
msgstr "Nomes de formatos suportados:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:10
msgid "`gzip` and `gz`"
msgstr "`gzip` e `gz`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:11
msgid "`zlib`"
msgstr "`zlib`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:12
msgid "`deflate`"
msgstr "`deflate`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:13
msgid "`bzip2` and `bz2`"
msgstr "`bzip2` e `bz2`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:14
msgid "`xz`"
msgstr "`xz`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:15
msgid "`zstd`, `zst`, and `zstandard`"
msgstr "`zstd`, `zst` e `zstandard`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:17
msgid "ptool.zip.compress"
msgstr "ptool.zip.compress"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:19
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:19"
msgid "`v0.8.0` - Introduced."
msgstr "`v0.8.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:21
msgid ""
"`ptool.zip.compress(format, input)` compresses a Lua string with the "
"requested format."
msgstr ""
"`ptool.zip.compress(format, input)` comprime uma string Lua com o "
"formato solicitado."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:24
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:24"
msgid "`format` (string, required): The compression format name."
msgstr "`format` (string, obrigatório): O nome do formato de compressão."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:25
msgid ""
"`input` (string, required): The input Lua string. Compression uses the "
"string's raw bytes unchanged."
msgstr ""
"`input` (string, obrigatório): A string Lua de entrada. A compressão usa os "
"bytes brutos da string sem modificá-los."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:27
msgid "Returns: `string` (compressed bytes as a Lua string)."
msgstr "Retorna: `string` (bytes comprimidos como uma string Lua)."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:29
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:29"
msgid "Error behavior:"
msgstr "Comportamento em caso de erro:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:31
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:31"
msgid "An error is raised if `format` is not a supported format name."
msgstr "Um erro é gerado se `format` não for um nome de formato suportado."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:32
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:32"
msgid "An error is raised if `input` is not a string."
msgstr "Um erro é gerado se `input` não for uma string."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:33
msgid "An error is raised if the encoder fails for the requested format."
msgstr "Um erro é gerado se o codificador falhar para o formato solicitado."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:35
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:35"
msgid "Example:"
msgstr "Exemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:44
msgid "ptool.zip.decompress"
msgstr "ptool.zip.decompress"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:46
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:46"
msgid "`v0.8.0` - Introduced."
msgstr "`v0.8.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:48
msgid ""
"`ptool.zip.decompress(format, input)` decompresses a Lua string with the "
"requested format."
msgstr ""
"`ptool.zip.decompress(format, input)` descomprime uma string Lua com o "
"formato solicitado."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:51
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:51"
msgid "`format` (string, required): The compression format name."
msgstr "`format` (string, obrigatório): O nome do formato de compressão."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:52
msgid "`input` (string, required): The compressed Lua string."
msgstr "`input` (string, obrigatório): A string Lua comprimida."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:53
msgid "Returns: `string` (decompressed bytes as a Lua string)."
msgstr "Retorna: `string` (bytes descomprimidos como uma string Lua)."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:55
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:55"
msgid "Error behavior:"
msgstr "Comportamento em caso de erro:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:57
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:57"
msgid "An error is raised if `format` is not a supported format name."
msgstr "Um erro é gerado se `format` não for um nome de formato suportado."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:58
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:58"
msgid "An error is raised if `input` is not a string."
msgstr "Um erro é gerado se `input` não for uma string."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:59
msgid ""
"An error is raised if `input` is not valid data for the requested format."
msgstr "Um erro é gerado se `input` não contiver dados válidos para o formato solicitado."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:61
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/terse-bay/ptool/website/docs/lua-api/zip.md:61"
msgid "Example:"
msgstr "Exemplo:"

