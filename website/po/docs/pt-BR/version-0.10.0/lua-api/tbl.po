#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:48
msgid "`nil` and `false` remove the current item."
msgstr "`nil` e `false` removem o item atual."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:49
msgid "Any other Lua value keeps the current item."
msgstr "Qualquer outro valor Lua mantém o item atual."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:50
msgid "The returned table is reindexed from `1`."
msgstr "A tabela retornada é reindexada a partir de `1`."

