msgid "List Rules"
msgstr "Regras de lista"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:307
msgid "`ptool.tbl` currently supports only dense list tables."
msgstr "`ptool.tbl` atualmente suporta apenas tabelas de lista densas."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:309
msgid "Keys must be integers."
msgstr "As chaves devem ser inteiras."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:310
msgid "Keys must start at `1`."
msgstr "As chaves devem começar em `1`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:311
msgid "Keys must be contiguous without gaps."
msgstr "As chaves devem ser contíguas, sem buracos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/tbl.md:312
msgid "Sparse tables and dictionary-style tables raise errors."
msgstr "Tabelas esparsas e tabelas no estilo dicionário geram erro."

