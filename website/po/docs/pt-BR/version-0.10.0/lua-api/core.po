msgid "Example:"
msgstr "Exemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:230
msgid "ptool.ask.confirm"
msgstr "ptool.ask.confirm"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:232
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:232"
msgid "`v0.5.0` - Introduced."
msgstr "`v0.5.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:234
msgid "`ptool.ask.confirm(prompt[, options])` asks the user for a yes/no answer."
msgstr "`ptool.ask.confirm(prompt[, options])` solicita ao usuário uma resposta de sim/não."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:236
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:236"
msgid "`prompt` (string, required): The prompt shown to the user."
msgstr "`prompt` (string, obrigatório): O prompt mostrado ao usuário."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:237
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:237"
