#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:1
msgid "Hash API"
msgstr "ハッシュ API"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:3
msgid "Hashing helpers are available under `ptool.hash` and `p.hash`."
msgstr "ハッシュヘルパーは `ptool.hash` と `p.hash` にあります。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:5
msgid "ptool.hash.sha256"
msgstr "ptool.hash.sha256"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:7"
msgid "`v0.2.0` - Introduced."
msgstr "`v0.2.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:9
msgid "`ptool.hash.sha256(input)` returns the SHA-256 digest of a Lua string."
msgstr "`ptool.hash.sha256(input)` は Lua 文字列の SHA-256 ダイジェストを返します。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:11
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:11"
msgid ""
"`input` (string, required): The input Lua string. The digest is computed "
"from the string's raw bytes."
msgstr "`input` (string, 必須): 入力となる Lua 文字列。ダイジェストは文字列の 生バイ"
"ト列から計算されます。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:13
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/hash.md:13"
msgid "Returns: `string` (lowercase hexadecimal digest)."
msgstr "戻り値: `string` (小文字の 16 進ダイジェスト)。"

