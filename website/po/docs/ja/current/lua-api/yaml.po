#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:1
msgid "YAML API"
msgstr "YAML API"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:3
msgid "YAML parsing and serialization helpers are available under `ptool.yaml` and `p.yaml`."
msgstr "YAML の解析とシリアライズのヘルパーは `ptool.yaml` と `p.yaml` に あります。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:6
msgid "ptool.yaml.parse"
msgstr "ptool.yaml.parse"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:8
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:8"
msgid "`v0.4.0` - Introduced."
msgstr "`v0.4.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:10
msgid "`ptool.yaml.parse(input)` parses a YAML string into a Lua value."
msgstr "`ptool.yaml.parse(input)` は YAML 文字列を Lua 値へ解析します。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:12
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:12"
msgid "`input` (string, required): The YAML text."
msgstr "`input` (string, 必須): YAML テキスト。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:13
msgid "Returns: The parsed Lua value. The root can be any supported YAML type."
msgstr "戻り値: 解析された Lua 値。ルートは対応している任意の YAML 型を使えます。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:15
msgid "Type mapping:"
msgstr "型対応:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:17
msgid "YAML mapping -> Lua table"
msgstr "YAML mapping -> Lua table"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:18
msgid "YAML sequence -> Lua sequence table (1-based)"
msgstr "YAML sequence -> Lua sequence table (1-based)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:19
msgid "YAML string -> Lua string"
msgstr "YAML string -> Lua string"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:20
msgid "YAML integer that fits in `i64` -> Lua integer"
msgstr "`i64` に収まる YAML integer -> Lua integer"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:21
msgid "Other YAML number -> Lua number"
msgstr "それ以外の YAML number -> Lua number"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:22
msgid "YAML boolean -> Lua boolean"
msgstr "YAML boolean -> Lua boolean"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:23
msgid "YAML null -> Lua `nil`"
msgstr "YAML null -> Lua `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:25
msgid "Error behavior:"
msgstr "エラー時の挙動:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:27
msgid "An error is raised if `input` is not a string."
msgstr "`input` が文字列でない場合はエラーになります。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:28
msgid "A YAML syntax error raises an error whose message includes parser detail."
msgstr "YAML 構文エラーでは、パーサー詳細を含むメッセージでエラーになります。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:29
msgid "An error is raised if the YAML value cannot be represented as a Lua value in `ptool`, such as a mapping with non-string keys or an explicit YAML tag."
msgstr "非文字列キーを持つ mapping や明示的な YAML tag など、`ptool` の Lua 値へ 変換できない YAML 値でもエラーになります。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/yaml.md:32
