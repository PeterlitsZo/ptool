msgstr "`ptool.semver.compare(a, b)` は 2 つのバージョンを比較します。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:44
msgid ""
"`a` / `b` (string|Version, required): A version string or a `Version` object."
msgstr "`a` / `b` (string|Version, 必須): バージョン文字列または `Version` オブジェク"
"ト。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:45
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:45"
msgid "Returns: `-1 | 0 | 1`."
msgstr "戻り値: `-1 | 0 | 1`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:51
msgid "ptool.semver.bump"
msgstr "ptool.semver.bump"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:53
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:53"
