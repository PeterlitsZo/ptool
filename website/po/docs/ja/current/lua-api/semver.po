#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:1
msgid "SemVer API"
msgstr "SemVer API"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:3
msgid "Version parsing, validation, comparison, version requirement matching, and bumping helpers live under `ptool.semver` and `p.semver`."
msgstr "バージョンの解析、検証、比較、バージョン要件の照合、更新のヘルパーは `ptool.semver` と `p.semver` にあります。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/semver.md:6
msgid "ptool.semver.parse"
msgstr "ptool.semver.parse"

