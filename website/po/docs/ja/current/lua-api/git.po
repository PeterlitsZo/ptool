msgstr "これにより、ベア リポジトリの場合は `nil` が返されます。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:163
msgid "is_bare"
msgstr "is_bare"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:165
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:165"
