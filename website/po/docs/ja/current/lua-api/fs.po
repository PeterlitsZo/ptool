msgstr "`Unreleased` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:171
msgid "Canonical API name: `ptool.fs.File:flush`."
msgstr "正規 API 名: `ptool.fs.File:flush`。"

