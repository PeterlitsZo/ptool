#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:3
msgid ""
"Template rendering helpers are available under `ptool.template` and "
"`p.template`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:5
msgid "ptool.template.render"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:7
msgid "`v0.1.0` - Introduced."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:9
msgid ""
"`ptool.template.render(template, context)` renders a Jinja-style template "
"string and returns the rendered result."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:12
msgid "`template` (string, required): The template source text."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:13
msgid "`context` (any serializable Lua value, required): The template context."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/template.md:14
msgid "Returns: The rendered string."
msgstr ""

