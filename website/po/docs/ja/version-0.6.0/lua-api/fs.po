#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:144
msgid "ptool.fs.glob"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:146
msgid "`v0.2.0` - Introduced. `v0.5.0` - Added the `working_dir` option."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:149
msgid ""
"`ptool.fs.glob(pattern[, options])` matches filesystem paths using Unix-"
"style glob syntax and returns a string array of matched paths sorted "
"lexicographically."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:153
msgid ""
"`pattern` (string, required): A glob pattern. Relative patterns are resolved "
"from the current `ptool` runtime directory, so they follow `ptool.cd(...)`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:155
msgid "`options` (table, optional): Glob options. Supported fields:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:155
msgid ""
"`working_dir` (string, optional): Override the base directory used to "
"resolve relative patterns. Relative `working_dir` values are resolved from "
"the current `ptool` runtime directory."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:159
msgid "Returns: `string[]`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/fs.md:160
msgid ""
"Hidden files and directories are matched only when the corresponding pattern "
"component explicitly starts with `.`."
msgstr ""

