#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:7
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:9
msgid "`ptool.sh.split(command)` parses a command string using shell-style rules and returns an argument array."
msgstr "`ptool.sh.split(command)` はシェル風ルールでコマンド文字列を解析し、 引数配列を返します。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:12
msgid "`command` (string, required): The command string to split."
msgstr "`command` (string, 必須): 分割するコマンド文字列。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:13
msgid "Returns: `string[]`."
msgstr "戻り値: `string[]`。"

