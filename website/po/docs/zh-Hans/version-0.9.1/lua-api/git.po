msgstr "`repo:is_clean([options])` -> `boolean`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:134
msgid "`repo:add(paths[, options])` -> `nil`"
msgstr "`repo:add(paths[, options])` -> `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:135
msgid "`repo:commit(message[, options])` -> `string`"
