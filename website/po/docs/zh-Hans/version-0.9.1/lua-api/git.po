msgid "Example:"
msgstr "示例："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:39
msgid "ptool.git.discover"
msgstr "ptool.git.discover"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:41
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:41"
msgid "`v0.6.0` - Introduced."
msgstr "`v0.6.0` - 引入。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/git.md:43
msgid "`ptool.git.discover(path?)` finds a repository starting from `path` and walking up parent directories, then returns a `Repo` object."
msgstr "`ptool.git.discover(path?)` 从 `path` 开始向上遍历父目录查找仓库，然后返回一个 `Repo` 对象。"

