msgstr "`conn:exists(path)` -> `boolean`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/ssh.md:118
msgid "`conn:is_file(path)` -> `boolean`"
msgstr "`conn:is_file(path)` -> `boolean`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/ssh.md:118
