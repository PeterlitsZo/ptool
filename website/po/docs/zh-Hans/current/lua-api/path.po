#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:1
msgid "Path API"
msgstr "Path API"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:3
msgid "Lexical path helpers are available under `ptool.path` and `p.path`."
msgstr "纯词法路径辅助能力位于 `ptool.path` 和 `p.path` 下。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:5
msgid "ptool.path.join"
msgstr "ptool.path.join"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:7"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - 引入。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:9
msgid ""
"`ptool.path.join(...segments)` joins multiple path segments and returns the "
"normalized path."
msgstr "`ptool.path.join(...segments)` 拼接多个路径片段，并返回规范化路径。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:12
msgid "`segments` (string, at least one): Path segments."
msgstr "`segments`（string，至少一个）：路径片段。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:13
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/path.md:13"
