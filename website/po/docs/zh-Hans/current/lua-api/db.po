msgstr "`rows`（table）：行表数组。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:105
msgid "`columns` (table): An array of column names."
msgstr "`columns`（table）：列名数组。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:106
msgid "`row_count` (integer): The number of rows returned."
msgstr "`row_count`（integer）：返回的行数。"

