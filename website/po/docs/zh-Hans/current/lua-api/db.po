msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:85"
msgid "`string`"
msgstr "`string`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:85
msgid "`nil` (for SQL `NULL`)"
msgstr "`nil`（对应 SQL `NULL`）"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:91
msgid "Text columns are returned as Lua strings."
msgstr "文本列会作为 Lua 字符串返回。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:92
msgid "Binary/blob columns are also returned as Lua strings."
msgstr "二进制 / blob 列也会作为 Lua 字符串返回。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:93
msgid ""
"If a query result contains duplicate column names, an error is raised. Use "
"SQL aliases such as `AS` to disambiguate them."
msgstr "如果查询结果中出现重复列名，会抛出错误。请使用 `AS` 等 SQL 别名消除歧义。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:96
