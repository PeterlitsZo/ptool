msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:76"
msgid "`string`"
msgstr "`string`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:81
msgid "`nil` is not supported as a bound parameter in `v0.1.0`."
msgstr "在 `v0.1.0` 中，不支持将 `nil` 作为绑定参数。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:83
msgid "Result value rules:"
msgstr "结果值规则："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:85
msgid "Query results only guarantee these Lua value types:"
msgstr "查询结果仅保证返回以下 Lua 值类型："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:85
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/db.md:85"
msgid "`boolean`"
