#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/re.md:45
msgid ""
"`Regex` represents a compiled regular expression returned by "
"`ptool.re.compile(...)`."
msgstr "`Regex` 表示由 `ptool.re.compile(...)` 返回的已编译正则表达式。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/re.md:48
msgid "It is implemented as a Lua userdata."
msgstr "它实现为 Lua userdata。"

