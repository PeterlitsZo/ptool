msgstr "示例："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:51
msgid "ptool.fs.mkdir"
msgstr "ptool.fs.mkdir"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:53
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:53"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - 引入。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:55
msgid ""
"`ptool.fs.mkdir(path)` creates a directory. If parent directories do not "
"exist, they are created recursively."
msgstr "`ptool.fs.mkdir(path)` 创建目录。如果父目录不存在，会递归创建。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:58
msgid "`path` (string, required): The directory path."
msgstr "`path`（string，必填）：目录路径。"

