#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:66
msgid "ptool.fs.exists"
msgstr "ptool.fs.exists"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:68
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:68"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - 引入。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:70
msgid "`ptool.fs.exists(path)` checks whether a path exists."
msgstr "`ptool.fs.exists(path)` 检查路径是否存在。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:72
msgid "`path` (string, required): A file or directory path."
msgstr "`path`（string，必填）：文件或目录路径。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/fs.md:73
msgid "Returns: `boolean`."
msgstr "返回：`boolean`。"

