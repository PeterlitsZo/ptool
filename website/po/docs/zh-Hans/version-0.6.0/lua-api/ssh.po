#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:1
msgid "SSH API"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:3
msgid ""
"SSH connection, remote execution, and file transfer helpers are available "
"under `ptool.ssh` and `p.ssh`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:5
msgid "ptool.ssh.connect"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:7"
msgid "`v0.1.0` - Introduced."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:9
msgid ""
"`ptool.ssh.connect(target_or_options)` prepares an SSH connection handle "
"backed by the system `ssh` command and returns a `Connection` object."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:12
msgid "`ssh` must be available on `PATH`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:14
msgid "Arguments:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "`target_or_options` (string|table, required):"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "When a string is provided, it is treated as an SSH target."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "When a table is provided, it currently supports:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid ""
"`target` (string, optional): SSH target string such as `"
"\"deploy@example.com\"` or `\"deploy@example.com:2222\"`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "`host` (string, optional): Hostname or IP address."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid ""
"`user` (string, optional): SSH username. Defaults to `$USER`, or `\"root\"` "
"if `$USER` is unavailable."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "`port` (integer, optional): SSH port. Defaults to `22`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "`auth` (table, optional): Authentication settings."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid "`host_key` (table, optional): Host key verification settings."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid ""
"`connect_timeout_ms` (integer, optional): Timeout in milliseconds. Defaults "
"to `10000`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:16
msgid ""
"`keepalive_interval_ms` (integer, optional): Keepalive interval in "
"milliseconds."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:32
msgid "Supported target string examples:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:40
msgid "`auth` fields:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:42
msgid "`private_key_file` (string, optional): Path to a private key file."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:43
msgid ""
"`private_key_passphrase` (string, optional): Passphrase for the private key. "
"This is currently not supported."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:45
msgid ""
"`password` (string, optional): Password-based authentication. This is "
"currently not supported."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:48
msgid "Authentication behavior:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:50
msgid ""
"If `auth.private_key_file` is provided, `ptool` invokes `ssh` with that key "
"via `-i` and also sets `IdentitiesOnly=yes`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:52
msgid ""
"If `auth.private_key_passphrase` or `auth.password` is provided, "
"`ptool.ssh.connect(...)` fails because this API does not pass those secrets "
"to the system `ssh` command."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:55
msgid ""
"Otherwise, authentication is delegated to the local OpenSSH setup, including "
"settings and mechanisms such as `IdentityFile`, `ProxyJump`, `ProxyCommand`, "
"`ssh-agent`, and certificates."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:58
msgid ""
"Relative key paths are resolved from the current `ptool` runtime directory, "
"so they follow `ptool.cd(...)`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:60
msgid "`~` and `~/...` are expanded in key paths."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:62
msgid "`host_key` fields:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:64
msgid ""
"`verify` (string, optional): Host key verification mode. Supported values:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:64
msgid "`\"known_hosts\"`: Verify against a known_hosts file (default)."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:64
msgid "`\"ignore\"`: Skip host key verification."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:67
msgid ""
"`known_hosts_file` (string, optional): Path to a known_hosts file. Used only "
"when `verify = \"known_hosts\"`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:70
msgid "Host key behavior:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:72
msgid ""
"If `verify = \"ignore\"`, `ptool` invokes `ssh` with "
"`StrictHostKeyChecking=no` and `UserKnownHostsFile=/dev/null`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:74
msgid ""
"If `verify = \"known_hosts\"` and `known_hosts_file` is provided, `ptool` "
"invokes `ssh` with `StrictHostKeyChecking=yes` and that `UserKnownHostsFile`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:77
msgid ""
"If `verify = \"known_hosts\"` and `known_hosts_file` is omitted, or when "
"`host_key` is omitted entirely, host key handling is delegated to the local "
"OpenSSH configuration and defaults."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:80
msgid ""
"Relative `known_hosts_file` paths are resolved from the current `ptool` "
"runtime directory."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:82
msgid "`~` and `~/...` are expanded in `known_hosts_file`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/ssh.md:83
msgid ""
"When `known_hosts_file` is provided explicitly, it overrides the default "
"`UserKnownHostsFile` used by the local `ssh` command for this connection."
msgstr ""

