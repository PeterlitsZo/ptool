msgstr "ptool.inspect"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/core.md:85
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/core.md:85"
msgid "`v0.1.0` - Introduced."
