msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/os.md:58"
msgid "`name` (string, required): Environment variable name."
msgstr "`name`（string，必填）：环境变量名。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/os.md:59
msgid "`value` (string, required): Environment variable value."
msgstr "`value`（string，必填）：环境变量值。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/os.md:61
