msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:111
msgid "Common node fields:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:113
msgid "`title` (string, optional): Draws a block title around the node."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:114
msgid ""
"`border` (boolean, optional): Draws a border around the node. Defaults to "
"`false`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:116
msgid "`padding` (integer, optional): Uniform inner padding. Defaults to `0`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:117
msgid ""
"`grow` (integer, optional): Relative size when the node is inside a row or "
"column. Defaults to `1`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:119
msgid "`style` (table, optional): Shared style fields:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:119
msgid ""
"`fg` / `bg`: One of `black`, `red`, `green`, `yellow`, `blue`, `magenta`, "
"`cyan`, `white`, `gray`, or `dark_gray`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:119
msgid ""
"`bold`, `dim`, `italic`, `underlined`, `reversed`: Boolean style toggles."
msgstr ""

