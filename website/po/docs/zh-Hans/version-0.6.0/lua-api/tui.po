#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:142
msgid ""
"`options.selected` (integer, optional): The selected row using Lua's 1-based "
"indexing. Values beyond the item count are ignored."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:144
msgid ""
"`options.highlight_style` (table, optional): Style applied to the selected "
"row. Uses the same keys as `style`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:147
msgid "Notes:"
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:149
msgid ""
