#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:1
msgid "S3 API"
msgstr "S3 API"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:3
msgid "S3-compatible object storage helpers are available under `ptool.s3` and `p.s3`."
msgstr "S3 兼容对象存储辅助能力位于 `ptool.s3` 和 `p.s3` 下。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:5
msgid "ptool.s3.connect"
msgstr "ptool.s3.connect"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:7"
msgid "`v0.10.0` - Introduced."
msgstr "`v0.10.0` - 引入。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:9
msgid "`ptool.s3.connect(options)` opens an S3-compatible object storage connection and returns a `Connection` object."
msgstr "`ptool.s3.connect(options)` 打开一个 S3 兼容对象存储连接，并返回一个 `Connection` 对象。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:12
msgid "`options` fields:"
msgstr "`options` 字段："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:14
msgid "`bucket` (string, required): The bucket name."
msgstr "`bucket`（string，必填）：bucket 名称。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:15
msgid "`region` (string, optional): The AWS region or provider region."
msgstr "`region`（string，选填）：AWS 区域或服务提供商区域。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:16
msgid "`endpoint` (string, optional): A custom S3-compatible endpoint URL such as MinIO, R2, or another object storage service."
msgstr "`endpoint`（string，选填）：自定义的 S3 兼容 endpoint URL，例如 MinIO、R2 或其他对象存储服务。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:18
msgid "`access_key_id` (string, optional): The access key ID."
msgstr "`access_key_id`（string，选填）：访问密钥 ID。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:19
msgid "`secret_access_key` (string, optional): The secret access key."
msgstr "`secret_access_key`（string，选填）：访问密钥 secret。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:20
msgid "`session_token` (string, optional): The session token."
msgstr "`session_token`（string，选填）：会话令牌。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:21
msgid "`root` (string, optional): A root prefix applied to all object operations."
msgstr "`root`（string，选填）：应用到所有对象操作的根前缀。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:22
msgid "`allow_anonymous` (boolean, optional): When `true`, allow unsigned requests if credentials are not configured. Defaults to `false`."
msgstr "`allow_anonymous`（boolean，选填）：当为 `true` 时，如果未配置凭证，则允许未签名请求。默认为 `false`。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:25
msgid "Environment fallback:"
msgstr "环境变量回退："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:27
msgid "Explicit `options` values win."
msgstr "显式传入的 `options` 值优先。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:28
msgid "Missing `region`, `endpoint`, `access_key_id`, `secret_access_key`, and `session_token` values fall back to:"
msgstr "缺失的 `region`、`endpoint`、`access_key_id`、`secret_access_key` 和 `session_token` 会回退到："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:28
msgid "`AWS_REGION`"
msgstr "`AWS_REGION`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:28
msgid "`AWS_ENDPOINT`, `AWS_ENDPOINT_URL`, or `AWS_S3_ENDPOINT`"
msgstr "`AWS_ENDPOINT`、`AWS_ENDPOINT_URL` 或 `AWS_S3_ENDPOINT`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:28
msgid "`AWS_ACCESS_KEY_ID`"
msgstr "`AWS_ACCESS_KEY_ID`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:28
msgid "`AWS_SECRET_ACCESS_KEY`"
msgstr "`AWS_SECRET_ACCESS_KEY`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:28
msgid "`AWS_SESSION_TOKEN`"
msgstr "`AWS_SESSION_TOKEN`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:35
msgid "Environment fallback uses `ptool`'s runtime environment view, so values set through `p.os.setenv(...)` are also visible to `ptool.s3.connect(...)`."
msgstr "环境变量回退使用 `ptool` 的运行时环境视图，因此通过 `p.os.setenv(...)` 设置的值也会被 `ptool.s3.connect(...)` 看到。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:38
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:38"
msgid "Example:"
msgstr "示例："

