msgid "`conn:exists(path)` -> `boolean`"
msgstr "`conn:exists(path)` -> `boolean`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:66
msgid "`conn:list([prefix])` -> `table`"
msgstr "`conn:list([prefix])` -> `table`"

