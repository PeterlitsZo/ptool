#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:69
msgid "Path rules:"
msgstr "路径规则："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:71
msgid "Object paths must be non-empty strings unless otherwise noted."
msgstr "除非另有说明，对象路径必须是非空字符串。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:72
msgid "Leading `/` is ignored, so `/foo/bar.txt` and `foo/bar.txt` target the same object."
msgstr "前导 `/` 会被忽略，因此 `/foo/bar.txt` 和 `foo/bar.txt` 指向同一个对象。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:74
msgid "Paths are relative to `root` when `root` is configured on the connection."
msgstr "当连接配置了 `root` 时，路径会相对于 `root` 解析。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:76
msgid "Entry table shape:"
msgstr "条目 table 结构："

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:78
msgid "`path` (string): The object path relative to the connection root."
msgstr "`path`（string）：相对于连接根路径的对象路径。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:79
msgid "`size` (integer): The object size in bytes."
msgstr "`size`（integer）：对象大小，单位为字节。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:80
msgid "`etag` (string | nil): The object ETag when available."
msgstr "`etag`（string | nil）：对象的 ETag（如果可用）。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:81
msgid "`last_modified` (string | nil): The last-modified timestamp when available."
msgstr "`last_modified`（string | nil）：最后修改时间戳（如果可用）。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:82
msgid "`content_type` (string | nil): The object content type when available."
msgstr "`content_type`（string | nil）：对象内容类型（如果可用）。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:83
msgid "`is_file` (boolean): Whether the entry is a file."
msgstr "`is_file`（boolean）：该条目是否为文件。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:84
msgid "`is_dir` (boolean): Whether the entry is a directory."
msgstr "`is_dir`（boolean）：该条目是否为目录。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:85
msgid "`mode` (string): One of `\"file\"`, `\"dir\"`, or `\"unknown\"`."
msgstr "`mode`（string）：`\"file\"`、`\"dir\"` 或 `\"unknown\"` 之一。"

