msgid "`v0.10.0` - Introduced."
msgstr "`v0.10.0` - 引入。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:55
msgid "`Connection` represents an open object storage connection returned by `ptool.s3.connect()`."
msgstr "`Connection` 表示由 `ptool.s3.connect()` 返回的已打开对象存储连接。"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/s3.md:58
msgid "It is implemented as a Lua userdata."
msgstr "它实现为 Lua userdata。"

