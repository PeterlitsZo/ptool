msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/core.md:706
msgid ""
"Each stage can be an array such as `{\"tr\", \"a-z\", \"A-Z\"}` where the "
"first item is the command and the rest are arguments."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/core.md:708
msgid ""
"Each stage can be a table such as `{ cmd = \"tr\", args = {\"a-z\", \"A-Z\"} "
"}`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/core.md:709
msgid ""
"Stage command strings and string argslines are split using shell-style "
"(`shlex`) rules, just like `ptool.run(...)`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/core.md:712
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.10.0/lua-api/core.md:712"
