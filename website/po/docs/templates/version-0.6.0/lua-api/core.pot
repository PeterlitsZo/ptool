#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/core.md:586
msgid "`stderr` defaults to `\"capture\"`."
msgstr ""

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/core.md:588
msgid "You can still override either field explicitly in `options`."
