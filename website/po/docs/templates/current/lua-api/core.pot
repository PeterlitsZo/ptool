#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:897
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/core.md:897"
msgid "`{ file = \"path\" }`: Write stderr to a file, truncating it first."
msgstr ""

