msgstr "`timezone` (cadena)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:150
msgid "Methods:"
msgstr "Métodos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:150
