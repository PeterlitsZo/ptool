msgstr "`month` (entero)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
msgid "`day` (integer)"
msgstr "`day` (entero)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
msgid "`hour` (integer)"
msgstr "`hour` (entero)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
msgid "`minute` (integer)"
msgstr "`minute` (entero)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
msgid "`second` (integer)"
msgstr "`second` (entero)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
msgid "`nanosecond` (integer)"
msgstr "`nanosecond` (entero)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
msgid "`offset` (string)"
msgstr "`offset` (cadena)"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/datetime.md:140
