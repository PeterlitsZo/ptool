#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:117
msgid "ptool.fs.remove"
msgstr "ptool.fs.remove"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:119
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:119"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:121
msgid ""
"`ptool.fs.remove(path[, options])` removes a file, symlink, or directory."
msgstr ""
"`ptool.fs.remove(path[, options])` elimina un archivo, enlace simbólico o "
"directorio."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:123
msgid "`path` (string, required): The path to remove."
msgstr "`path` (string, obligatorio): La ruta que se va a eliminar."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:124
msgid "`options` (table, optional): Remove options. Supported fields:"
msgstr "`options` (table, opcional): Opciones de eliminación. Campos admitidos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:124
msgid ""
"`recursive` (boolean, optional): Whether to remove directories recursively. "
"Defaults to `false`."
msgstr ""
"`recursive` (boolean, opcional): Indica si los directorios deben eliminarse "
"recursivamente. Valor predeterminado: `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:124
msgid ""
"`missing_ok` (boolean, optional): Whether to ignore missing paths. Defaults "
"to `false`."
msgstr ""
"`missing_ok` (boolean, opcional): Indica si deben ignorarse las rutas "
"ausentes. Valor predeterminado: `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:130
msgid "Behavior:"
msgstr "Comportamiento:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:132
msgid "Files and symlinks can be removed without `recursive`."
msgstr "Los archivos y enlaces simbólicos pueden eliminarse sin `recursive`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:133
msgid "Directories require `recursive = true` when they are not empty."
msgstr "Los directorios necesitan `recursive = true` cuando no están vacíos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/fs.md:134
msgid "Unknown option names or invalid option value types raise an error."
msgstr ""
"Los nombres de opción desconocidos o los tipos de valor inválidos producen "
"un error."

