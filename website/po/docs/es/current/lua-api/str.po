msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:248"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:250
msgid "`ptool.str.indent(s, prefix[, options])` adds `prefix` to each line."
msgstr "`ptool.str.indent(s, prefix[, options])` añade `prefix` a cada línea."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:252
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:252"
msgid "`s` (string, required): The input string."
msgstr "`s` (string, obligatorio): La cadena de entrada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:253
msgid "`prefix` (string, required): The text inserted before each line."
msgstr "`prefix` (string, obligatorio): El texto insertado antes de cada línea."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:254
msgid "`options` (table, optional): Indent options. Supported fields:"
msgstr "`options` (table, opcional): Opciones de indentación. Campos admitidos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:254
msgid ""
"`skip_first` (boolean, optional): Whether to leave the first line unchanged. "
"Defaults to `false`."
msgstr ""
"`skip_first` (boolean, opcional): Si la primera línea se deja sin cambios. "
"Por defecto es `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:257
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:257"
msgid "Returns: `string`."
msgstr "Devuelve: `string`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:259
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:259"
msgid "Behavior:"
msgstr "Comportamiento:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:261
msgid "Existing line endings are preserved."
msgstr "Se conservan los finales de línea existentes."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:262
msgid "Empty input is returned unchanged."
msgstr "Una entrada vacía se devuelve sin cambios."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:263
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/str.md:263"
msgid "Unknown option names or invalid option value types raise an error."
msgstr ""
"Los nombres de opción desconocidos o tipos de valor no válidos producen un "
"error."
