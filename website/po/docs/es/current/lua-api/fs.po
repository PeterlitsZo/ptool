#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:73
msgid "ptool.fs.open"
msgstr "ptool.fs.open"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:75
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:75"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:77
msgid ""
"`ptool.fs.open(path[, mode])` opens a local file and returns a `File` object."
msgstr ""
"`ptool.fs.open(path[, mode])` abre un archivo local y devuelve un objeto "
"`File`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:79
msgid "Arguments:"
msgstr "Argumentos:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:81
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:81"
msgid "`path` (string, required): The file path."
msgstr "`path` (string, obligatorio): La ruta del archivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:82
msgid "`mode` (string, optional): The file mode. Defaults to `\"r\"`."
msgstr ""
"`mode` (string, opcional): El modo del archivo. Valor predeterminado: `\"r\""
"`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:84
msgid "Supported modes:"
msgstr "Modos admitidos:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:86
msgid "`\"r\"`: Open for reading."
msgstr "`\"r\"`: Abre para lectura."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:87
msgid ""
"`\"w\"`: Open for writing, truncating existing contents and creating the "
"file when needed."
msgstr ""
"`\"w\"`: Abre para escritura, trunca el contenido existente y crea el "
"archivo cuando hace falta."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:89
msgid "`\"a\"`: Open for appending, creating the file when needed."
msgstr "`\"a\"`: Abre para anexar, creando el archivo cuando hace falta."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:90
msgid "`\"r+\"`: Open for reading and writing without truncation."
msgstr "`\"r+\"`: Abre para lectura y escritura sin truncar."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:91
msgid ""
"`\"w+\"`: Open for reading and writing, truncating existing contents and "
"creating the file when needed."
msgstr ""
"`\"w+\"`: Abre para lectura y escritura, trunca el contenido existente y "
"crea el archivo cuando hace falta."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:93
msgid ""
"`\"a+\"`: Open for reading and appending, creating the file when needed."
msgstr ""
"`\"a+\"`: Abre para lectura y anexado, creando el archivo cuando hace falta."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:95
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:95"
msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:97
msgid "Modes may include `b`, such as `\"rb\"` or `\"w+b\"`."
msgstr "Los modos pueden incluir `b`, como `\"rb\"` o `\"w+b\"`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:98
msgid "`a` and `a+` writes always go to the end of the file."
msgstr "Las escrituras con `a` y `a+` siempre van al final del archivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:100
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:100"
msgid "Example:"
msgstr "Ejemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:109
msgid "File"
msgstr "File"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:111
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:111"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:113
msgid ""
"`File` represents an open local file handle returned by `ptool.fs.open()`."
msgstr ""
"`File` representa un manejador de archivo local abierto devuelto por "
"`ptool.fs.open()`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:115
msgid "It is implemented as a Lua userdata."
msgstr "Está implementado como un userdata de Lua."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:117
msgid "Methods:"
msgstr "Métodos:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:119
msgid "`file:read([n])` -> `string`"
msgstr "`file:read([n])` -> `string`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:120
msgid "`file:write(content)` -> `nil`"
msgstr "`file:write(content)` -> `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:121
msgid "`file:flush()` -> `nil`"
msgstr "`file:flush()` -> `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:122
msgid "`file:seek([whence[, offset]])` -> `integer`"
msgstr "`file:seek([whence[, offset]])` -> `integer`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:123
msgid "`file:close()` -> `nil`"
msgstr "`file:close()` -> `nil`"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:125
msgid "read"
msgstr "read"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:127
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:127"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:129
msgid "Canonical API name: `ptool.fs.File:read`."
msgstr "Nombre canónico de la API: `ptool.fs.File:read`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:131
msgid ""
"`file:read([n])` reads bytes from the current file position and returns them "
"as a Lua string."
msgstr ""
"`file:read([n])` lee bytes desde la posición actual del archivo y los "
"devuelve como una cadena Lua."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:134
msgid ""
"`n` (integer, optional): The maximum number of bytes to read. If omitted, "
"reads from the current file position to EOF."
msgstr ""
"`n` (integer, opcional): El número máximo de bytes que se leen. Si se omite, "
"lee desde la posición actual hasta EOF."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:136
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:136"
msgid "Returns: `string`."
msgstr "Devuelve: `string`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:138
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:138"
msgid "Behavior:"
msgstr "Comportamiento:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:140
msgid "Returns an empty string at EOF."
msgstr "Devuelve una cadena vacía en EOF."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:141
msgid "Reads raw bytes, so binary data is preserved exactly."
msgstr ""
"Lee bytes sin procesar, por lo que los datos binarios se conservan "
"exactamente."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:143
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:143"
msgid "Example:"
msgstr "Ejemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:152
msgid "write"
msgstr "write"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:154
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:154"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:156
msgid "Canonical API name: `ptool.fs.File:write`."
msgstr "Nombre canónico de la API: `ptool.fs.File:write`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:158
msgid "`file:write(content)` writes a Lua string at the current file position."
msgstr ""
"`file:write(content)` escribe una cadena Lua en la posición actual del "
"archivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:160
msgid "`content` (string, required): The bytes to write."
msgstr "`content` (string, obligatorio): Los bytes que se van a escribir."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:162
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:162"
msgid "Behavior:"
msgstr "Comportamiento:"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:164
msgid "Writes raw bytes exactly as provided."
msgstr "Escribe bytes sin procesar exactamente como se proporcionan."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:165
msgid "On append-mode handles, writes are appended to the end of the file."
msgstr ""
"En los manejadores en modo append, las escrituras se agregan al final del "
"archivo."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:167
msgid "flush"
msgstr "flush"

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:169
msgctxt "/Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:169"
msgid "`Unreleased` - Introduced."
msgstr "`Unreleased` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:171
msgid "Canonical API name: `ptool.fs.File:flush`."
msgstr "Nombre canónico de la API: `ptool.fs.File:flush`."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:173
msgid "`file:flush()` flushes buffered file writes to the OS."
msgstr ""
"`file:flush()` vacía en el SO las escrituras del archivo almacenadas en "
"búfer."

#: /Users/peterlits/Proj/PeterlitsZo/worktrees/ptool/fresh-vale/ptool/website/docs/lua-api/fs.md:175
msgid "seek"
msgstr "seek"

