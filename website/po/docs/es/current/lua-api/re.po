#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:1
msgid "Regex API"
msgstr "API de regex"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:3
msgid "Regular expression helpers are available under `ptool.re` and `p.re`."
msgstr ""
"Las utilidades de expresiones regulares están disponibles bajo `ptool.re` y "
"`p.re`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:5
msgid "ptool.re.compile"
msgstr "ptool.re.compile"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:7"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:9
msgid ""
"`ptool.re.compile(pattern[, opts])` compiles a regular expression and "
"returns a `Regex` object."
msgstr ""
"`ptool.re.compile(pattern[, opts])` compila una expresión regular y devuelve "
"un objeto `Regex`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:12
msgid "`pattern` (string, required): The regex pattern."
msgstr "`pattern` (string, obligatorio): El patrón regex."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:13
msgid "`opts` (table, optional): Compile options. Currently supported:"
msgstr ""
"`opts` (table, opcional): Opciones de compilación. Actualmente se admite:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:13
msgid ""
"`case_insensitive` (boolean, optional): Whether matching is case-"
"insensitive. Defaults to `false`."
msgstr ""
"`case_insensitive` (boolean, opcional): Si la coincidencia distingue entre "
"mayúsculas y minúsculas. Por defecto es `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:17
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:17"
msgid "Example:"
msgstr "Ejemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:24
msgid "ptool.re.escape"
msgstr "ptool.re.escape"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:26
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:26"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:28
msgid "`ptool.re.escape(text)` escapes plain text into a regex literal string."
msgstr ""
"`ptool.re.escape(text)` escapa texto plano para convertirlo en una cadena "
"literal de regex."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:30
msgid "`text` (string, required): The text to escape."
msgstr "`text` (string, obligatorio): El texto que se va a escapar."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:31
msgid "Returns: The escaped string."
msgstr "Devuelve: La cadena escapada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:33
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:33"
msgid "Example:"
msgstr "Ejemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:41
msgid "Regex"
msgstr "Regex"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:43
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:43"
