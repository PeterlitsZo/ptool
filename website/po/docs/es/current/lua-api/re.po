#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:45
msgid ""
"`Regex` represents a compiled regular expression returned by "
"`ptool.re.compile(...)`."
msgstr ""
"`Regex` representa una expresión regular compilada devuelta por "
"`ptool.re.compile(...)`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:48
msgid "It is implemented as a Lua userdata."
msgstr "Está implementada como userdata de Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:50
msgid "Methods:"
msgstr "Métodos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:52
msgid "`re:is_match(input)` -> `boolean`"
msgstr "`re:is_match(input)` -> `boolean`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:53
msgid "`re:find(input[, init])` -> `Match|nil`"
msgstr "`re:find(input[, init])` -> `Match|nil`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:54
msgid "`re:find_all(input)` -> `Match[]`"
msgstr "`re:find_all(input)` -> `Match[]`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:55
msgid "`re:captures(input)` -> `Captures|nil`"
msgstr "`re:captures(input)` -> `Captures|nil`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:56
msgid "`re:captures_all(input)` -> `Captures[]`"
msgstr "`re:captures_all(input)` -> `Captures[]`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:57
msgid "`re:replace(input, replacement)` -> `string`"
msgstr "`re:replace(input, replacement)` -> `string`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:58
msgid "`re:replace_all(input, replacement)` -> `string`"
msgstr "`re:replace_all(input, replacement)` -> `string`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:59
msgid "`re:split(input[, limit])` -> `string[]`"
msgstr "`re:split(input[, limit])` -> `string[]`"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:61
msgid "is_match"
msgstr "is_match"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:63
msgid "Canonical API name: `ptool.re.Regex:is_match`."
msgstr "Canonical API name: `ptool.re.Regex:is_match`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:65
msgid "`re:is_match(input)` checks whether the regex matches `input`."
msgstr "`re:is_match(input)` comprueba si la regex coincide con `input`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:67
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:67"
msgid "`input` (string, required): The input text."
msgstr "`input` (string, obligatorio): El texto de entrada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:68
msgid "Returns: `boolean`."
msgstr "Devuelve: `boolean`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:70
msgid "find"
msgstr "find"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:72
msgid "Canonical API name: `ptool.re.Regex:find`."
msgstr "Canonical API name: `ptool.re.Regex:find`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:74
msgid "`re:find(input[, init])` returns the first match in `input`, or `nil`."
msgstr ""
"`re:find(input[, init])` devuelve la primera coincidencia en `input`, o "
"`nil`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:76
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:76"
msgid "`input` (string, required): The input text."
msgstr "`input` (string, obligatorio): El texto de entrada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:78
msgid "Parameter notes:"
msgstr "Notas de parámetros:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:80
msgid "`init` is a 1-based start position and defaults to `1`."
msgstr "`init` es una posición inicial basada en 1 y por defecto vale `1`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:81
msgid "`limit` must be greater than `0`."
msgstr "`limit` debe ser mayor que `0`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:83
msgid "Return structures:"
msgstr "Estructuras devueltas:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:85
msgid "`Match`:"
msgstr "`Match`:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:85
msgid "`start` (integer): The 1-based start index."
msgstr "`start` (integer): Índice inicial basado en 1."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:85
msgid "`finish` (integer): The end index, directly usable with `string.sub`."
msgstr ""
"`finish` (integer): Índice final, utilizable directamente con `string.sub`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:85
msgid "`text` (string): The matched text."
msgstr "`text` (string): El texto coincidente."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:89
msgid "`Captures`:"
msgstr "`Captures`:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:89
msgid "`full` (string): The full matched text."
msgstr "`full` (string): El texto completo coincidente."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:89
msgid ""
"`groups` (table): An array of capture groups in capture order. Unmatched "
"groups are `nil`."
msgstr ""
"`groups` (table): Un arreglo de grupos capturados en orden de captura. Los "
"grupos no coincidentes son `nil`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:89
msgid ""
"`named` (table): A mapping of named capture groups, keyed by group name."
msgstr ""
"`named` (table): Un mapa de grupos capturados con nombre, indexado por "
"nombre de grupo."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:95
msgid "find_all"
msgstr "find_all"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:97
msgid "Canonical API name: `ptool.re.Regex:find_all`."
msgstr "Canonical API name: `ptool.re.Regex:find_all`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:99
msgid "`re:find_all(input)` returns all matches in `input` as a `Match[]`."
msgstr ""
"`re:find_all(input)` devuelve todas las coincidencias en `input` como "
"`Match[]`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:101
msgid "captures"
msgstr "captures"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:103
msgid "Canonical API name: `ptool.re.Regex:captures`."
msgstr "Canonical API name: `ptool.re.Regex:captures`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:105
msgid ""
"`re:captures(input)` returns the first capture set in `input`, or `nil`."
msgstr ""
"`re:captures(input)` devuelve el primer conjunto de capturas en `input`, o "
"`nil`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:107
msgid "captures_all"
msgstr "captures_all"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:109
msgid "Canonical API name: `ptool.re.Regex:captures_all`."
msgstr "Canonical API name: `ptool.re.Regex:captures_all`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:111
msgid ""
"`re:captures_all(input)` returns all capture sets in `input` as a "
"`Captures[]`."
msgstr ""
"`re:captures_all(input)` devuelve todos los conjuntos de capturas en `input` "
"como `Captures[]`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:113
msgid "replace"
msgstr "replace"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:115
msgid "Canonical API name: `ptool.re.Regex:replace`."
msgstr "Canonical API name: `ptool.re.Regex:replace`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:117
msgid "`re:replace(input, replacement)` replaces the first match in `input`."
msgstr ""
"`re:replace(input, replacement)` reemplaza la primera coincidencia en "
"`input`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:119
msgid "replace_all"
msgstr "replace_all"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:121
msgid "Canonical API name: `ptool.re.Regex:replace_all`."
msgstr "Canonical API name: `ptool.re.Regex:replace_all`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:123
msgid "`re:replace_all(input, replacement)` replaces all matches in `input`."
msgstr ""
"`re:replace_all(input, replacement)` reemplaza todas las coincidencias en "
"`input`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:125
msgid "split"
msgstr "split"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:127
msgid "Canonical API name: `ptool.re.Regex:split`."
msgstr "Canonical API name: `ptool.re.Regex:split`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:129
msgid ""
"`re:split(input[, limit])` splits `input` using the regex as the separator."
msgstr ""
"`re:split(input[, limit])` divide `input` usando la regex como separador."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/re.md:131
