#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:1
msgid "HTTP API"
msgstr "API HTTP"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:3
msgid "HTTP client helpers are available under `ptool.http` and `p.http`."
msgstr ""
"Las utilidades de cliente HTTP están disponibles bajo `ptool.http` y "
"`p.http`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:5
msgid "ptool.http.request"
msgstr "ptool.http.request"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:7
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:7"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:9
msgid ""
"`ptool.http.request(options)` sends an HTTP request and returns a `Response` "
"object."
msgstr ""
"`ptool.http.request(options)` envía una solicitud HTTP y devuelve un objeto "
"`Response`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:12
msgid ""
"To send the same request shape from a remote SSH host, use "
"`ptool.ssh.Connection:http_request(options)`."
msgstr ""
"Para enviar la misma forma de solicitud desde un host SSH remoto, use "
"`ptool.ssh.Connection:http_request(options)`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:15
msgid "`options` fields:"
msgstr "Campos de `options`:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:17
msgid "`url` (string, required): The request URL."
msgstr "`url` (string, obligatorio): La URL de la solicitud."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:18
msgid "`method` (string, optional): The HTTP method. Defaults to `\"GET\"`."
msgstr "`method` (string, opcional): El método HTTP. Por defecto es `\"GET\"`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:19
msgid ""
"`headers` (table, optional): Request headers, where both keys and values are "
"strings."
msgstr ""
"`headers` (table, opcional): Cabeceras de la solicitud, donde tanto claves "
"como valores son cadenas."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:21
msgid ""
"`query` (table, optional): Query parameters appended to the request URL. "
"Keys must be strings. Values may be strings, numbers, or booleans."
msgstr ""
"`query` (table, opcional): Parámetros de consulta añadidos a la URL de la "
"solicitud. Las claves deben ser cadenas. Los valores pueden ser cadenas, "
"números o booleanos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:23
msgid "`body` (string, optional): The request body."
msgstr "`body` (string, opcional): El cuerpo de la solicitud."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:24
msgid ""
"`json` (Lua value, optional): A Lua value encoded as JSON and used as the "
"request body. When `content-type` is not already set, it defaults to `"
"application/json`."
msgstr ""
"`json` (valor Lua, opcional): Un valor Lua codificado como JSON y usado como "
"cuerpo de la solicitud. Si `content-type` no está definido, se usa por "
"defecto `application/json`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:27
msgid ""
"`form` (table, optional): Form fields encoded as `application/x-www-form-"
"urlencoded` and used as the request body. Keys must be strings. Values may "
"be strings, numbers, or booleans."
msgstr ""
"`form` (table, opcional): Campos codificados como `application/x-www-form-"
"urlencoded` y usados como cuerpo de la solicitud. Las claves deben ser "
"cadenas. Los valores pueden ser cadenas, números o booleanos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:30
msgid ""
"`timeout_ms` (integer, optional): Timeout in milliseconds. Defaults to "
"`30000`."
msgstr ""
"`timeout_ms` (integer, opcional): Tiempo de espera en milisegundos. Por "
"defecto es `30000`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:32
msgid ""
"`connect_timeout_ms` (integer, optional): Connection timeout in milliseconds."
msgstr ""
"`connect_timeout_ms` (integer, opcional): Tiempo límite de conexión en "
"milisegundos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:33
msgid ""
"`follow_redirects` (boolean, optional): Whether redirects should be followed."
msgstr ""
"`follow_redirects` (boolean, opcional): Si deben seguirse las redirecciones."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:34
msgid ""
"`max_redirects` (integer, optional): Maximum number of redirects to follow."
msgstr ""
"`max_redirects` (integer, opcional): Número máximo de redirecciones a seguir."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:35
msgid "`user_agent` (string, optional): Sets the `user-agent` request header."
msgstr "`user_agent` (string, opcional): Establece la cabecera `user-agent`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:36
msgid ""
"`basic_auth` (table, optional): HTTP basic auth credentials with string "
"fields `username` and `password`."
msgstr ""
"`basic_auth` (table, opcional): Credenciales HTTP Basic con campos de cadena "
"`username` y `password`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:38
msgid ""
"`bearer_token` (string, optional): Bearer token used for the `authorization` "
"header."
msgstr ""
"`bearer_token` (string, opcional): Token Bearer usado para la cabecera "
"`authorization`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:40
msgid ""
"`fail_on_http_error` (boolean, optional): When `true`, raise an error for "
"4xx and 5xx HTTP responses. Defaults to `false`."
msgstr ""
"`fail_on_http_error` (boolean, opcional): Si es `true`, las respuestas HTTP "
"4xx y 5xx producen un error. El valor por defecto es `false`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:43
#, fuzzy
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:43"
msgid "Notes:"
msgstr "Notas:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:45
msgid "`body`, `json`, and `form` are mutually exclusive."
msgstr "`body`, `json` y `form` son mutuamente excluyentes."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:46
msgid "`basic_auth` and `bearer_token` are mutually exclusive."
msgstr "`basic_auth` y `bearer_token` son mutuamente excluyentes."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:48
msgid "Example:"
msgstr "Ejemplo:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:72
msgid "Response"
msgstr "Response"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:74
#, fuzzy
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:74"
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introducido."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:76
msgid ""
"`Response` represents an HTTP response returned by `ptool.http.request(...)`."
msgstr ""
"`Response` representa una respuesta HTTP devuelta por `ptool.http.request"
"(...)`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:78
msgid "Fields:"
msgstr "Campos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:80
msgid "`status` (integer): The HTTP status code."
msgstr "`status` (integer): El código de estado HTTP."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:81
msgid "`ok` (boolean): Whether the status code is in the 2xx range."
msgstr "`ok` (boolean): Si el código de estado está en el rango 2xx."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:82
msgid "`url` (string): The final URL after redirects."
msgstr "`url` (string): La URL final después de las redirecciones."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:83
msgid ""
"`headers` (table): A flattened convenience view of response headers "
"(`table<string, string>`). Repeated headers are merged with `, `."
msgstr ""
"`headers` (table): Vista simplificada de las cabeceras de la respuesta "
"(`table<string, string>`). Las cabeceras repetidas se unen con `, `."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:86
msgid "Methods:"
msgstr "Métodos:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:88
msgid "`resp:text()`: Reads and returns the response body as text."
msgstr "`resp:text()`: Lee y devuelve el cuerpo de la respuesta como texto."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:89
msgid ""
"`resp:json()`: Reads the response body, parses it as JSON, and returns a Lua "
"value."
msgstr ""
"`resp:json()`: Lee el cuerpo de la respuesta, lo analiza como JSON y "
"devuelve un valor Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:91
msgid "`resp:bytes()`: Reads and returns the raw bytes (as a Lua string)."
msgstr ""
"`resp:bytes()`: Lee y devuelve los bytes sin procesar como una cadena Lua."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:92
msgid ""
"`resp:header(name)`: Returns the first matching response header value, or "
"`nil`."
msgstr ""
"`resp:header(name)`: Devuelve el primer valor de cabecera coincidente, o "
"`nil`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:94
msgid ""
"`resp:header_values(name)`: Returns all matching response header values as "
"an array."
msgstr ""
"`resp:header_values(name)`: Devuelve todos los valores de cabecera "
"coincidentes como un arreglo."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/docs/lua-api/http.md:96
msgid ""
"`resp:raise_for_status()`: Raises an error for 4xx and 5xx HTTP responses."
msgstr ""
"`resp:raise_for_status()`: Produce un error para respuestas HTTP 4xx y 5xx."

