#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:82
msgid "`ptool.yaml.stringify(value)` converts a Lua value to YAML text."
msgstr "`ptool.yaml.stringify(value)` convierte un valor Lua en texto YAML."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:84
msgid "`value` (YAML-compatible Lua value, required): The value to encode."
msgstr "`value` (valor Lua compatible con YAML, obligatorio): El valor que se va a codificar."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:85
msgid "Returns: The encoded YAML string."
msgstr "Devuelve: La cadena YAML codificada."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:87
