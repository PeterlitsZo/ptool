msgid "Behavior:"
msgstr "Comportamiento:"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:62
msgid "String path segments select mapping keys."
msgstr "Los segmentos de ruta string seleccionan claves de mappings."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:63
msgid "Integer path segments select sequence elements using Lua's 1-based indexing."
msgstr "Los segmentos de ruta integer seleccionan elementos de secuencias usando índices Lua base 1."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/yaml.md:65
