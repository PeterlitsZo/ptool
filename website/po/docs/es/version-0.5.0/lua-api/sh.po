msgid "Shell API"
msgstr "API de shell"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:3
msgid "Shell parsing helpers are available under `ptool.sh` and `p.sh`."
msgstr ""
"Las utilidades de análisis de shell están disponibles bajo `ptool.sh` y "
"`p.sh`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:5
msgid "ptool.sh.split"
msgstr "ptool.sh.split"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:7
msgid "`v0.1.0` - Introduced."
msgstr "`v0.1.0` - Introduced."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:9
msgid ""
"`ptool.sh.split(command)` parses a command string using shell-style rules "
"and returns an argument array."
msgstr ""
"`ptool.sh.split(command)` analiza una cadena de comando usando reglas de "
"estilo shell y devuelve un arreglo de argumentos."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:12
msgid "`command` (string, required): The command string to split."
msgstr ""
"`command` (string, obligatorio): La cadena de comando que se va a dividir."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.5.0/lua-api/sh.md:13
msgid "Returns: `string[]`."
msgstr "Devuelve: `string[]`."

