#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:128
msgid "`ptool.tui.text(text[, options])` creates a text node."
msgstr "`ptool.tui.text(text[, options])` crea un nodo de texto."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:130
msgid "`text` (string, required): The text to render."
msgstr "`text` (string, obligatorio): El texto a renderizar."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:131
msgid ""
"`options.align` (string, optional): `left`, `center`, or `right`. Defaults "
"to `left`."
msgstr ""
"`options.align` (string, opcional): `left`, `center` o `right`. El valor por "
"defecto es `left`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:134
msgid "ptool.tui.list"
msgstr "ptool.tui.list"

