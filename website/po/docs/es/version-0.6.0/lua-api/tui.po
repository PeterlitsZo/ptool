msgstr "quit"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:97
msgid "Canonical API name: `ptool.tui.App:quit`."
msgstr "Canonical API name: `ptool.tui.App:quit`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:99
msgid ""
"`app:quit(value?)` requests that the TUI session stop after the current "
"callback completes."
msgstr ""
"`app:quit(value?)` solicita detener la sesión TUI cuando termine el callback "
"actual."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:102
msgid ""
"`value` (Lua value, optional): The value returned by `ptool.tui.run(...)`."
msgstr ""
"`value` (valor Lua, opcional): El valor devuelto por `ptool.tui.run(...)`."

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:104
msgid "Node Constructors"
msgstr "Constructores de nodos"

#: /Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:106
msgctxt "/Users/peterlits/Proj/PeterlitsZo/ptool/website/versioned_docs/version-0.6.0/lua-api/tui.md:106"
